{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "假名打字通",
  "version": "0.7.1",
  "identifier": "app.kana-typing.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "假名打字通",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost ws://localhost:1420 ws://127.0.0.1:1420",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png"]
  }
}
